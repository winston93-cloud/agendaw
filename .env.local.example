NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_agendaw
SUPABASE_SERVICE_ROLE_KEY=tu_api_key_agendaw

# InsForge Winston Servicios — búsqueda alumno (Familia Winston)
WINSTON_SERVICIOS_URL=https://TU_APPKEY_WS.us-east.insforge.app
WINSTON_SERVICIOS_API_KEY=tu_api_key_winston_servicios

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin — PINs de acceso por rol (5 accesos independientes)
ADMIN_PIN_PSI_MK=pin_psicologia_maternal_kinder
ADMIN_PIN_PSI_PRI=pin_psicologia_primaria
ADMIN_PIN_PSI_SEC=pin_psicologia_secundaria
ADMIN_PIN_VIN_MK=pin_vinculacion_maternal_kinder
ADMIN_PIN_VIN_PRI=pin_vinculacion_primaria

# Dashboard directoras — PINs por nivel
DIRECTOR_PIN_MK=pin_directora_maternal_kinder
DIRECTOR_PIN_PRI=pin_directora_primaria
DIRECTOR_PIN_SEC=pin_directora_secundaria

# SMS Mobile API
SMSMOBILEAPI_API_KEY=tu_api_key_de_la_app

# MySQL (Hosting PHPMyAdmin) — alta definitiva hasta lanzamiento
MYSQL_HOST=www.winston93.edu.mx
MYSQL_USER=winston_richard
MYSQL_PASSWORD=tu_password
MYSQL_DATABASE=winston_general
MYSQL_PORT=3306

# Correo remitente (avisos no-reply)
MAIL_USER=avisos_no-replay@winston93.edu.mx
MAIL_PASS=tu_password_de_correo

# Google Calendar - Service Account (Domain-Wide Delegation)
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_PRIVATE_KEY_AQUI\n-----END PRIVATE KEY-----\n"

